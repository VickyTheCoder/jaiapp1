MDScreen:

    MDTopAppBar:
        title: "Document Finalizer"
        pos_hint: {"top": 1}

    MDBoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        MDCard:
            orientation: "vertical"
            padding: 15
            spacing: 10
            size_hint_y: None
            height: "140dp"

            MDLabel:
                text: "Selected Document"
                bold: True

            MDLabel:
                id: doc_label
                text: "None"
                theme_text_color: "Hint"

            MDRaisedButton:
                text: "Choose Document"
                on_release: app.pick_document()

        MDCard:
            orientation: "vertical"
            padding: 15
            spacing: 10
            size_hint_y: None
            height: "140dp"

            MDLabel:
                text: "Selected Image"
                bold: True

            MDLabel:
                id: img_label
                text: "None"
                theme_text_color: "Hint"

            MDRaisedButton:
                text: "Choose Image"
                on_release: app.pick_image()

        MDBoxLayout:
            spacing: 20
            size_hint_y: None
            height: "60dp"

            MDRaisedButton:
                id: final_btn
                text: "Final Copy"
                disabled: True
                on_release: app.create_final_pdf()

            MDFlatButton:
                id: share_btn
                text: "Share"
                disabled: True
                on_release: app.share_file()